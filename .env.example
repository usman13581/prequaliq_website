# PostgreSQL — website + future AI metadata
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Railway: link Postgres DATABASE_URL to the website service.
# Migrations run automatically on every deploy via: npm start → scripts/migrate.mjs

# Transactional email (Resend) — confirmation emails to form submitters
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM=PrequaliQ <info@prequaliq.com>

# Local only — create tables without migrations:
# npm run db:push

# After changing src/db/schema.ts — create a new migration:
# npm run db:generate -- --name describe_your_change
# Commit the new file under drizzle/ and push.
