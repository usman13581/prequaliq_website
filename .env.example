# PostgreSQL — website + future AI metadata
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Railway: link Postgres DATABASE_URL to the website service.
# Migrations run automatically on every deploy via: npm start → scripts/migrate.mjs

# Transactional email (Resend) — requires prequaliq.com verified at resend.com/domains
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM=PrequaliQ <info@prequaliq.com>

# Local only — create tables without migrations:
# npm run db:push

# After changing src/db/schema.ts — create a new migration:
# npm run db:generate -- --name describe_your_change
# Commit the new file under drizzle/ and push.

# Admin CMS — generate a long random string for ADMIN_SESSION_SECRET
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password

# AI chatbot (OpenAI) — server-side only; never expose to the browser
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini
CHAT_EMBEDDING_MODEL=text-embedding-3-small
CHAT_SIMILARITY_THRESHOLD=0.68
CHAT_MAX_MESSAGES_PER_HOUR=25

# After migrate + OPENAI_API_KEY: npm run chat:index

# Set ADMIN_UPDATE_PASSWORD=1 on one deploy to reset an existing admin password.
# Or run: npm run db:reset-admin-password (with DATABASE_URL + ADMIN_PASSWORD)

# After migrate: npm run db:seed-admin
